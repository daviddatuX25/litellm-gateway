# =============================================================================
# LiteLLM Gateway — Environment Variables
# Copy to .env and fill in values
# =============================================================================

# Master key for the LiteLLM proxy admin API
# Generate: openssl rand -base64 32
LITELLM_MASTER_KEY=sk-litellm-master-change-me

# OpenRouter API key (from your OpenCode subscription)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# PostgreSQL password (auto-generated, keep safe)
POSTGRES_PASSWORD=change-me-to-a-random-password

# Optional: future provider keys
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
